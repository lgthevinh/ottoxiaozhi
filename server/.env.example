# Server
PYTHONUNBUFFERED=1

# Auth
# Use a long random secret in real environments. Do not commit real secrets.
SECRET_KEY=replace_with_a_long_random_secret_key

# Neon Postgres
# Replace these with values from your Neon project dashboard.
POSTGRES_HOST=your-neon-host.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password
POSTGRES_SSLMODE=require

# Standard Postgres connection URL for tools and future app code.
DATABASE_URL=postgresql://your_database_user:your_database_password@your-neon-host.neon.tech:5432/your_database_name?sslmode=require
